{
  "name": "@gmode/gateway",
  "version": "0.1.1",
  "description": "Focused API gateway runtime for GMode on Cloudflare Workers.",
  "keywords": [
    "cloudflare",
    "workers",
    "cloudflare-workers",
    "api",
    "gateway",
    "typescript",
    "api-gateway",
    "openapi",
    "middleware",
    "rate-limit",
    "service-bindings"
  ],
  "license": "MIT",
  "author": "Charl Kruger",
  "homepage": "https://github.com/charl-kruger/gmode#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/charl-kruger/gmode.git",
    "directory": "packages/gateway"
  },
  "bugs": "https://github.com/charl-kruger/gmode/issues",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo",
    "lint": "biome lint src"
  },
  "dependencies": {
    "@gmode/core": "workspace:*",
    "@hono/swagger-ui": "^0.5.0",
    "hono": "^4.6.12",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "5.20260706.1",
    "@gmode/service": "workspace:*",
    "@gmode/testing": "workspace:*",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
