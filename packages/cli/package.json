{
  "name": "@gmode/cli",
  "version": "0.1.0",
  "description": "GMode CLI for Cloudflare API Shield workflows.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/charl-kruger/gmode.git",
    "directory": "packages/cli"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "gmode": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup src/index.ts src/bin.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@gmode/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "22.20.0",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
