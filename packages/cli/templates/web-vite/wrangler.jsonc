{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "__WORKER_NAME__",
  "main": "src/server.ts",
  "compatibility_date": "2026-07-01",
  // Private web app: reached through the gateway's Service Binding.
  "workers_dev": false,
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./dist/client",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["__MOUNT__/api/*", "/__gmode/*"]
  }
}
