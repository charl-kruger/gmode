{
  "name": "@gmode/web",
  "version": "0.1.0",
  "description": "Run full web apps (TanStack Start, Vite SPAs) as GMode gateway services with typed, documented APIs.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/charl-kruger/gmode.git",
    "directory": "packages/web"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo",
    "lint": "biome lint src"
  },
  "dependencies": {
    "@gmode/core": "workspace:*"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "5.20260706.1",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
