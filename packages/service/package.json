{
  "name": "@gmode/service",
  "version": "0.1.1",
  "description": "Private service Worker runtime for GMode.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/charl-kruger/gmode.git",
    "directory": "packages/service"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo",
    "lint": "biome lint src"
  },
  "dependencies": {
    "@gmode/core": "workspace:*",
    "hono": "^4.6.12",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "5.20260706.1",
    "@gmode/testing": "workspace:*",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
