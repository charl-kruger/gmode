{
  "name": "gmode",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "type": "module",
  "description": "Typed gateway and service framework for Cloudflare Workers.",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "test:e2e": "pnpm --filter @gmode/e2e test",
    "test:e2e:smoke": "pnpm --filter @gmode/e2e test:smoke",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "publish-packages": "pnpm -r --filter '@gmode/*' publish --access public --provenance --no-git-checks --report-summary",
    "release": "pnpm build && pnpm publish-packages"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/charl-kruger/gmode.git"
  },
  "keywords": [
    "cloudflare",
    "workers",
    "gateway",
    "service-bindings",
    "api"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@changesets/cli": "2.31.0",
    "@cloudflare/workers-types": "5.20260706.1",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "turbo": "^2.5.3",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5",
    "wrangler": "4.101.0"
  }
}
